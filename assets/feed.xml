---
layout: compress
permalink: /feed.xml
sitemap: false
---

{% capture source %}
<feed xmlns="http://www.w3.org/2005/Atom">
  <id>{{ "/" | absolute_url }}</id>
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | strip | xml_escape }}</subtitle>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.social.name | default: site.title | xml_escape }}</name>
    <uri>{{ "/" | absolute_url }}</uri>
  </author>
  <link rel="self" type="application/atom+xml" href="{{ page.url | absolute_url }}"/>
  <link rel="alternate" type="text/html" hreflang="{{ site.alt_lang | default: site.lang }}" href="{{ "/" | absolute_url }}"/>
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <rights>Copyright {{ "now" | date: "%Y" }} {{ site.social.name | default: site.title | xml_escape }}</rights>
  <icon>{{ "/assets/img/favicons/favicon.ico" | relative_url }}</icon>
  <logo>{{ "/assets/img/favicons/android-chrome-192x192.png" | relative_url }}</logo>
{% for post in site.posts limit: 5 %}
  {% assign post_absolute_url = post.url | absolute_url %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post_absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}"/>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post_absolute_url }}</id>
    <content src="{{ post_absolute_url }}"/>
    <author>
      <name>{{ post.author | default: site.social.name | default: site.title | xml_escape }}</name>
    </author>
    {% for category in post.categories %}
    <category term="{{ category | xml_escape }}"/>
    {% endfor %}
    <summary>{% include post-description.html max_length=400 %}</summary>
  </entry>
{% endfor %}
</feed>
{% endcapture %}
{{ source | strip }}
